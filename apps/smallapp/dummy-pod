apiVersion: v1
kind: Pod
metadata:
  name: dummy-pod
  labels:
    app: dummy
spec:
  containers:
    - name: dummy-container
      image: busybox
      command: ["sleep", "3600"]   # just keeps running

---
apiVersion: v1
kind: Service
metadata:
  name: dummy-service
spec:
  selector:
    app: dummy
  ports:
    - protocol: TCP
      port: 80
      targetPort: 80
